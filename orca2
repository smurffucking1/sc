-- ─── Services ────────────────────────────────────────────────────────────────

local TweenService      = game:GetService("TweenService")
local UserInputService  = game:GetService("UserInputService")
local Players           = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

-- ─── Internal Helpers ────────────────────────────────────────────────────────

local function hex(h)
    h = h:gsub("^#", "")
    return Color3.fromRGB(
        tonumber(h:sub(1,2), 16),
        tonumber(h:sub(3,4), 16),
        tonumber(h:sub(5,6), 16)
    )
end

-- Spring-feel tween (mimics flipper Spring)
local function spring(obj, props, t, style, dir)
    t     = t     or 0.22
    style = style or Enum.EasingStyle.Back
    dir   = dir   or Enum.EasingDirection.Out
    TweenService:Create(obj, TweenInfo.new(t, style, dir), props):Play()
end

-- Fast snap tween (for hover feedback, color changes)
local function snap(obj, props, t)
    TweenService:Create(
        obj, TweenInfo.new(t or 0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props
    ):Play()
end

local function corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, col, thick, transp)
    local s = Instance.new("UIStroke")
    s.Color          = col   or Color3.new(1,1,1)
    s.Thickness      = thick or 1
    s.Transparency   = transp or 0.82
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function pad(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 0)
    p.PaddingRight  = UDim.new(0, right  or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.PaddingLeft   = UDim.new(0, left   or 0)
    p.Parent = parent
    return p
end

local function list(parent, dir, spacing)
    local l = Instance.new("UIListLayout")
    l.FillDirection       = dir or Enum.FillDirection.Vertical
    l.Padding             = UDim.new(0, spacing or 6)
    l.HorizontalAlignment = Enum.HorizontalAlignment.Left
    l.VerticalAlignment   = Enum.VerticalAlignment.Top
    l.SortOrder           = Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

local function frame(props)
    local f = Instance.new("Frame")
    f.BackgroundTransparency = props.BackgroundTransparency or 0
    for k, v in pairs(props) do pcall(function() f[k] = v end) end
    return f
end

local function label(props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Font     = Enum.Font.GothamMedium
    l.TextSize = 13
    l.RichText = true
    for k, v in pairs(props) do pcall(function() l[k] = v end) end
    return l
end

local function button(props)
    local b = Instance.new("TextButton")
    b.AutoButtonColor = false
    b.Font     = Enum.Font.GothamMedium
    b.TextSize = 13
    for k, v in pairs(props) do pcall(function() b[k] = v end) end
    return b
end

local function scrollFrame(props)
    local s = Instance.new("ScrollingFrame")
    s.ScrollBarThickness  = 2
    s.BorderSizePixel     = 0
    s.BackgroundTransparency = 1
    s.CanvasSize          = UDim2.new(0,0,0,0)
    s.AutomaticCanvasSize = Enum.AutomaticSize.Y
    for k, v in pairs(props) do pcall(function() s[k] = v end) end
    return s
end

-- Shadow using a blurred ImageLabel (Orca-style drop shadow)
local SHADOW_ID = "rbxassetid://6015897843"
local function addShadow(parent, col, transp)
    local img = Instance.new("ImageLabel")
    img.Name               = "Shadow"
    img.AnchorPoint        = Vector2.new(0.5, 0.5)
    img.Size               = UDim2.new(1, 30, 1, 30)
    img.Position           = UDim2.new(0.5, 0, 0.5, 4)
    img.BackgroundTransparency = 1
    img.Image              = SHADOW_ID
    img.ImageColor3        = col    or hex("#000000")
    img.ImageTransparency  = transp or 0.5
    img.ScaleType          = Enum.ScaleType.Slice
    img.SliceCenter        = Rect.new(49, 49, 450, 450)
    img.ZIndex             = parent.ZIndex - 1
    img.Parent             = parent
    return img
end

-- Glow asset IDs (from Orca source)
local GLOW = {
    Size70  = "rbxassetid://8992230903",
    Size146 = "rbxassetid://8992584561",
    Size198 = "rbxassetid://8992230677",
}

local function addGlow(parent, assetId, col, transp)
    local half = ({ [GLOW.Size70]=35, [GLOW.Size146]=73, [GLOW.Size198]=99 })[assetId] or 35
    local img = Instance.new("ImageLabel")
    img.Name               = "Glow"
    img.AnchorPoint        = Vector2.new(0.5, 0.5)
    img.Size               = UDim2.new(1, half*2, 1, half*2)
    img.Position           = UDim2.new(0.5, 0, 0.5, 0)
    img.BackgroundTransparency = 1
    img.Image              = assetId
    img.ImageColor3        = col    or Color3.new(1,1,1)
    img.ImageTransparency  = transp or 0.7
    img.ScaleType          = Enum.ScaleType.Slice
    img.SliceCenter        = Rect.new(Vector2.new(half, half), Vector2.new(half, half))
    img.ZIndex             = parent.ZIndex - 1
    img.Parent             = parent
    return img
end

