-- ─── Element Builder (Tab contents) ──────────────────────────────────────────

local Element = {}
Element.__index = Element

function Element.new(scroll, theme)
    return setmetatable({ _scroll = scroll, t = theme, _n = 0 }, Element)
end

function Element:_order()
    self._n += 1
    return self._n
end

-- ──────────────────────────────────────────────────────────────────────────────
--  SECTION HEADER
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Section(title)
    local t = self.t
    local f = frame({
        Size = UDim2.new(1, 0, 0, 22),
        BackgroundTransparency = 1,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    label({
        Text = title:upper(),
        Size = UDim2.new(1, -8, 1, 0),
        Position = UDim2.new(0, 4, 0, 0),
        TextColor3 = t.fgMuted,
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        LetterSpacing = 2,
        Parent = f,
    })
end

-- ──────────────────────────────────────────────────────────────────────────────
--  LABEL
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Label(text)
    local t = self.t
    local lbl = label({
        Text = text,
        Size = UDim2.new(1, 0, 0, 26),
        TextColor3 = t.fgMuted,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    pad(lbl, 0, 0, 0, 4)
    return { SetText = function(_, s) lbl.Text = s end }
end

-- ──────────────────────────────────────────────────────────────────────────────
--  BUTTON  — Orca style: dark card, glow on hover, accent glow on press
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Button(text, cb)
    local t = self.t

    local card = frame({
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = t.cardAlt,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    corner(card, t.elementRounding)
    addShadow(card, t.shadow, 0.7)

    -- Glow (hidden by default)
    local glow = addGlow(card, GLOW.Size70, t.accentA, 1)
    glow.Size = UDim2.new(1, 60, 1, 60)

    local lbl = label({
        Text = text,
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        TextColor3 = t.fg,
        Parent = card,
    })

    local btn = button({
        Text = "",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = card.ZIndex + 2,
        Parent = card,
    })

    btn.MouseEnter:Connect(function()
        snap(card, { BackgroundColor3 = t.cardAlt:Lerp(t.fg, 0.06) })
        snap(glow, { ImageTransparency = 0.88 })
    end)
    btn.MouseLeave:Connect(function()
        snap(card, { BackgroundColor3 = t.cardAlt })
        snap(glow, { ImageTransparency = 1 })
    end)
    btn.MouseButton1Down:Connect(function()
        snap(card, { BackgroundColor3 = t.accentA:Lerp(t.cardAlt, 0.6) }, 0.06)
        snap(glow, { ImageTransparency = 0.7 }, 0.06)
    end)
    btn.MouseButton1Up:Connect(function()
        snap(card, { BackgroundColor3 = t.cardAlt }, 0.15)
        snap(glow, { ImageTransparency = 1 }, 0.15)
    end)
    btn.Activated:Connect(function()
        if cb then task.spawn(cb) end
    end)

    return {
        SetText = function(_, s) lbl.Text = s end,
        SetCallback = function(_, fn) cb = fn end,
    }
end

-- ──────────────────────────────────────────────────────────────────────────────
--  TOGGLE  — Orca style: wide row, pill track with animated knob + accent fill
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Toggle(text, default, cb)
    local t = self.t
    local state = default == true

    local card = frame({
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = t.cardAlt,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    corner(card, t.elementRounding)
    addShadow(card, t.shadow, 0.7)

    label({
        Text = text,
        Size = UDim2.new(1, -70, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        TextColor3 = t.fg,
        Parent = card,
    })

    -- Track
    local track = frame({
        Size = UDim2.new(0, 38, 0, 20),
        Position = UDim2.new(1, -52, 0.5, -10),
        BackgroundColor3 = state and t.toggleOn or hex("#444444"),
        Parent = card,
    })
    corner(track, 10)

    -- Knob
    local knob = frame({
        Size = UDim2.new(0, 14, 0, 14),
        Position = state and UDim2.new(0, 21, 0.5, -7) or UDim2.new(0, 3, 0.5, -7),
        BackgroundColor3 = Color3.new(1,1,1),
        ZIndex = card.ZIndex + 1,
        Parent = track,
    })
    corner(knob, 7)

    -- Glow behind track
    local glow = addGlow(track, GLOW.Size70, t.toggleOn, 1)
    glow.Size = UDim2.new(1, 50, 1, 50)

    local function setState(v)
        state = v
        snap(track, { BackgroundColor3 = state and t.toggleOn or hex("#444444") }, 0.18)
        snap(knob, {
            Position = state and UDim2.new(0, 21, 0.5, -7)
                              or  UDim2.new(0, 3,  0.5, -7)
        }, 0.18)
        snap(glow, { ImageTransparency = state and 0.75 or 1 }, 0.18)
        if cb then task.spawn(cb, state) end
    end

    local btn = button({
        Text = "",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = card.ZIndex + 2,
        Parent = card,
    })
    btn.Activated:Connect(function() setState(not state) end)

    return {
        SetValue = function(_, v) setState(v) end,
        GetValue = function() return state end,
        SetText  = function(_, s)
            -- find label child
            for _, c in ipairs(card:GetChildren()) do
                if c:IsA("TextLabel") then c.Text = s break end
            end
        end,
    }
end

-- ──────────────────────────────────────────────────────────────────────────────
--  SLIDER  — Orca BrightSlider style: accent fill + glow that follows the fill
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Slider(text, min, max, default, cb)
    local t    = self.t
    min     = min or 0
    max     = max or 100
    local val  = math.clamp(default or min, min, max)

    local CARD_H = 56
    local card = frame({
        Size = UDim2.new(1, 0, 0, CARD_H),
        BackgroundColor3 = t.cardAlt,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    corner(card, t.elementRounding)
    addShadow(card, t.shadow, 0.7)

    -- Label row
    label({
        Text = text,
        Size = UDim2.new(1, -70, 0, 22),
        Position = UDim2.new(0, 16, 0, 7),
        TextColor3 = t.fg,
        Parent = card,
    })

    local valLbl = label({
        Text = tostring(math.round(val)),
        Size = UDim2.new(0, 52, 0, 22),
        Position = UDim2.new(1, -60, 0, 7),
        TextColor3 = t.fgMuted,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = card,
    })

    -- Track bg
    local trackBg = frame({
        Size = UDim2.new(1, -32, 0, 4),
        Position = UDim2.new(0, 16, 0, 40),
        BackgroundColor3 = t.card,
        Parent = card,
    })
    corner(trackBg, 2)

    -- Track fill
    local pct0  = (val - min) / (max - min)
    local fill  = frame({
        Size = UDim2.new(pct0, 0, 1, 0),
        BackgroundColor3 = t.sliderFill,
        Parent = trackBg,
    })
    corner(fill, 2)

    -- Glow on fill
    local fillGlow = addGlow(fill, GLOW.Size70, t.sliderFill, 0.7)
    fillGlow.Size = UDim2.new(1, 60, 1, 50)

    -- Invisible drag region
    local drag = button({
        Text = "",
        Size = UDim2.new(1, 0, 0, CARD_H),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        ZIndex = card.ZIndex + 3,
        Parent = card,
    })

    local dragging = false
    local function updateFromX(absX)
        local abs = trackBg.AbsolutePosition
        local absW = trackBg.AbsoluteSize.X
        local p = math.clamp((absX - abs.X) / absW, 0, 1)
        val = math.round(min + p * (max - min))
        snap(fill, { Size = UDim2.new(p, 0, 1, 0) }, 0.05)
        valLbl.Text = tostring(val)
        if cb then task.spawn(cb, val) end
    end

    drag.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateFromX(i.Position.X)
        end
    end)
    drag.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromX(i.Position.X)
        end
    end)

    return {
        SetValue = function(_, v)
            val = math.clamp(math.round(v), min, max)
            local p = (val - min) / (max - min)
            snap(fill, { Size = UDim2.new(p, 0, 1, 0) }, 0.12)
            valLbl.Text = tostring(val)
        end,
        GetValue = function() return val end,
        SetText  = function(_, s)
            for _, c in ipairs(card:GetChildren()) do
                if c:IsA("TextLabel") and c ~= valLbl then c.Text = s break end
            end
        end,
    }
end

-- ──────────────────────────────────────────────────────────────────────────────
--  DROPDOWN
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Dropdown(text, options, default, cb)
    local t    = self.t
    local sel  = default or (options and options[1]) or ""
    local open = false

    -- Wrapper (grows when open)
    local wrapper = frame({
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundTransparency = 1,
        ClipsDescendants = false,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })

    local head = frame({
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = t.cardAlt,
        Parent = wrapper,
    })
    corner(head, t.elementRounding)
    addShadow(head, t.shadow, 0.7)

    label({
        Text = text,
        Size = UDim2.new(0.55, -16, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        TextColor3 = t.fg,
        Parent = head,
    })

    local selLbl = label({
        Text = sel,
        Size = UDim2.new(0.4, -24, 1, 0),
        Position = UDim2.new(0.55, 4, 0, 0),
        TextColor3 = t.fgMuted,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = head,
    })

    local arrow = label({
        Text = "▾",
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -24, 0, 0),
        TextColor3 = t.fgMuted,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = head,
    })

    -- List (hidden)
    local listF = frame({
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 1, 6),
        BackgroundColor3 = t.cardAlt,
        ClipsDescendants = true,
        ZIndex = 20,
        Parent = wrapper,
    })
    corner(listF, t.elementRounding)
    list(listF, Enum.FillDirection.Vertical, 0)

    local function rebuild()
        for _, c in ipairs(listF:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for _, opt in ipairs(options or {}) do
            local ob = button({
                Text = opt,
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = t.cardAlt,
                TextColor3 = opt == sel and t.accentA or t.fg,
                TextXAlignment = Enum.TextXAlignment.Left,
                Font = Enum.Font.Gotham,
                ZIndex = 21,
                Parent = listF,
            })
            pad(ob, 0, 0, 0, 16)
            ob.MouseEnter:Connect(function()
                snap(ob, { BackgroundColor3 = t.cardAlt:Lerp(Color3.new(1,1,1), 0.05) })
            end)
            ob.MouseLeave:Connect(function()
                snap(ob, { BackgroundColor3 = t.cardAlt })
            end)
            ob.Activated:Connect(function()
                sel = opt
                selLbl.Text = sel
                open = false
                snap(listF, { Size = UDim2.new(1, 0, 0, 0) })
                snap(wrapper, { Size = UDim2.new(1, 0, 0, 40) })
                spring(arrow, { Rotation = 0 }, 0.18, Enum.EasingStyle.Back)
                rebuild()
                if cb then task.spawn(cb, sel) end
            end)
        end
    end
    rebuild()

    local headBtn = button({
        Text = "", Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1, ZIndex = head.ZIndex + 2,
        Parent = head,
    })
    headBtn.Activated:Connect(function()
        open = not open
        local count  = #(options or {})
        local listH  = math.min(count * 32, 160)
        local targetH = open and 40 + listH + 6 or 40
        snap(wrapper, { Size = UDim2.new(1, 0, 0, targetH) })
        snap(listF,   { Size = UDim2.new(1, 0, 0, open and listH or 0) })
        spring(arrow, { Rotation = open and 180 or 0 }, 0.2, Enum.EasingStyle.Back)
    end)

    return {
        SetOptions = function(_, opts) options = opts rebuild() end,
        SetValue   = function(_, v) sel = v selLbl.Text = v end,
        GetValue   = function() return sel end,
    }
end

-- ──────────────────────────────────────────────────────────────────────────────
--  TEXTBOX
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Textbox(text, placeholder, default, cb)
    local t = self.t

    local card = frame({
        Size = UDim2.new(1, 0, 0, 56),
        BackgroundColor3 = t.cardAlt,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    corner(card, t.elementRounding)
    addShadow(card, t.shadow, 0.7)

    label({
        Text = text,
        Size = UDim2.new(1, -16, 0, 20),
        Position = UDim2.new(0, 16, 0, 6),
        TextColor3 = t.fg,
        TextSize = 12,
        Parent = card,
    })

    local box = Instance.new("TextBox")
    box.Size             = UDim2.new(1, -32, 0, 24)
    box.Position         = UDim2.new(0, 16, 0, 28)
    box.BackgroundColor3 = t.card
    box.TextColor3       = t.fg
    box.PlaceholderText  = placeholder or ""
    box.PlaceholderColor3 = t.fgMuted
    box.Text             = default or ""
    box.Font             = Enum.Font.Gotham
    box.TextSize         = 13
    box.ClearTextOnFocus = false
    box.TextXAlignment   = Enum.TextXAlignment.Left
    box.Parent           = card
    corner(box, 6)
    pad(box, 0, 0, 0, 8)

    -- Highlight border on focus
    local boxStroke = stroke(box, t.accentA, 1, 1)
    box.Focused:Connect(function()
        snap(boxStroke, { Transparency = 0.5 })
    end)
    box.FocusLost:Connect(function(enter)
        snap(boxStroke, { Transparency = 1 })
        if cb then task.spawn(cb, box.Text, enter) end
    end)

    return {
        GetValue = function() return box.Text end,
        SetValue = function(_, v) box.Text = v end,
    }
end

-- ──────────────────────────────────────────────────────────────────────────────
--  KEYBIND  — Orca shortcuts panel style
-- ──────────────────────────────────────────────────────────────────────────────
function Element:Keybind(text, default, cb)
    local t    = self.t
    local key  = default or Enum.KeyCode.Unknown
    local wait = false

    local card = frame({
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = t.cardAlt,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    corner(card, t.elementRounding)
    addShadow(card, t.shadow, 0.7)

    label({
        Text = text,
        Size = UDim2.new(1, -110, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        TextColor3 = t.fg,
        Parent = card,
    })

    -- Key badge (right side, Orca shortcut style)
    local badge = frame({
        Size = UDim2.new(0, 86, 0, 28),
        Position = UDim2.new(1, -100, 0.5, -14),
        BackgroundColor3 = t.card,
        Parent = card,
    })
    corner(badge, t.elementRounding - 2)
    stroke(badge, Color3.new(1,1,1), 1, 0.88)

    local keyLbl = label({
        Text = key == Enum.KeyCode.Unknown and "Not bound" or key.Name,
        Size = UDim2.new(1, 0, 1, 0),
        TextColor3 = t.fgMuted,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextSize = 12,
        Parent = badge,
    })

    local btn = button({
        Text = "",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = card.ZIndex + 2,
        Parent = card,
    })
    btn.Activated:Connect(function()
        wait = true
        keyLbl.Text = "..."
        keyLbl.TextColor3 = t.accentA
    end)
    UserInputService.InputBegan:Connect(function(i, gpe)
        if wait and i.UserInputType == Enum.UserInputType.Keyboard then
            wait = false
            key = i.KeyCode
            keyLbl.Text = key.Name
            keyLbl.TextColor3 = t.fgMuted
            if cb then task.spawn(cb, key) end
        end
    end)

    return {
        GetValue = function() return key end,
        SetValue = function(_, k) key = k keyLbl.Text = k.Name end,
    }
end

-- ──────────────────────────────────────────────────────────────────────────────
--  COLOR PICKER (simple swatch row — Orca theme preview style)
-- ──────────────────────────────────────────────────────────────────────────────
function Element:ColorPicker(text, default, cb)
    local t   = self.t
    local col = default or Color3.new(1,1,1)

    local card = frame({
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = t.cardAlt,
        LayoutOrder = self:_order(),
        Parent = self._scroll,
    })
    corner(card, t.elementRounding)
    addShadow(card, t.shadow, 0.7)

    label({
        Text = text,
        Size = UDim2.new(1, -110, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        TextColor3 = t.fg,
        Parent = card,
    })

    -- Swatch circle
    local swatch = frame({
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -40, 0.5, -12),
        BackgroundColor3 = col,
        Parent = card,
    })
    corner(swatch, 12)
    stroke(swatch, Color3.new(1,1,1), 1, 0.8)

    -- (Full HSV picker UI would be very large; this provides the swatch hook)
    local obj = {
        GetValue = function() return col end,
        SetValue = function(_, c)
            col = c
            swatch.BackgroundColor3 = c
            if cb then task.spawn(cb, c) end
        end,
    }
    return obj
end

-- ─── Tab Object ───────────────────────────────────────────────────────────────

local Tab = {}
Tab.__index = Tab

-- Forward all Element methods onto Tab
for k, v in pairs(Element) do
    if type(v) == "function" and k ~= "new" then
        Tab[k] = v
    end
end

function Tab.new(scroll, theme)
    local self = setmetatable({}, Tab)
    self._scroll = scroll
    self.t       = theme
    self._n      = 0
    return self
end

function Tab:_order()
    self._n += 1
    return self._n
end

-- ─── Window ───────────────────────────────────────────────────────────────────

local Window = {}
Window.__index = Window

function Window.new(title, options)
    local self = setmetatable({}, Window)
    options    = options or {}

    self.Title  = title or "OrcaUI"
    self.t      = type(options.Theme) == "table" and options.Theme
                  or Themes[options.Theme] or Themes.Sorbet
    self.Toggle = options.Toggle or Enum.KeyCode.RightShift
    self._tabs  = {}

    self:_build()
    return self
end

function Window:_build()
    local t = self.t

    -- ScreenGui
    local sg = Instance.new("ScreenGui")
    sg.Name          = "OrcaUI"
    sg.IgnoreGuiInset = true
    sg.ResetOnSpawn  = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder  = 10
    local ok = pcall(function() sg.Parent = game:GetService("CoreGui") end)
    if not ok then sg.Parent = LocalPlayer:WaitForChild("PlayerGui") end
    self._gui = sg

    -- ── Outer container (centered, draggable) ──────────────────────────────
    -- Orca uses ~500px wide cards, bottom navbar
    -- Overall layout: content area (top) + navbar (bottom 52px)
    local TOTAL_W = 520
    local TOTAL_H = 420
    local NAV_H   = 52

    local root = frame({
        AnchorPoint = Vector2.new(0.5, 0.5),
        Size        = UDim2.new(0, TOTAL_W, 0, TOTAL_H),
        Position    = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundTransparency = 1,
        Parent      = sg,
    })
    self._root = root

    -- ── Content area (cards live here) ─────────────────────────────────────
    local contentArea = frame({
        Size            = UDim2.new(1, 0, 1, -NAV_H),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent          = root,
    })
    self._contentArea = contentArea

    -- ── Bottom Navbar ──────────────────────────────────────────────────────
    -- Matches Orca exactly: dark pill, icons + colored active state
    local navBg = frame({
        Size        = UDim2.new(1, 0, 0, NAV_H),
        Position    = UDim2.new(0, 0, 1, -NAV_H),
        BackgroundColor3 = t.navbar,
        Parent      = root,
    })
    corner(navBg, 16)
    addShadow(navBg, t.shadow, 0.5)
    if t.navbarStroke then
        stroke(navBg, Color3.new(1,1,1), 1, 0.88)
    end

    local navList = frame({
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 8, 0, 0),
        BackgroundTransparency = 1,
        Parent = navBg,
    })
    local navLayout = Instance.new("UIListLayout")
    navLayout.FillDirection       = Enum.FillDirection.Horizontal
    navLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    navLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
    navLayout.Padding             = UDim.new(0, 0)
    navLayout.SortOrder           = Enum.SortOrder.LayoutOrder
    navLayout.Parent              = navList

    self._navList = navList

    -- ── Entrance animation ─────────────────────────────────────────────────
    root.Size = UDim2.new(0, TOTAL_W, 0, 0)
    local rootTrans = Instance.new("UIScale")
    rootTrans.Scale = 0.92
    rootTrans.Parent = root

    task.defer(function()
        spring(root, { Size = UDim2.new(0, TOTAL_W, 0, TOTAL_H) }, 0.4,
            Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        spring(rootTrans, { Scale = 1 }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)

    -- ── Dragging ───────────────────────────────────────────────────────────
    local dragging, dragStart, rootStart = false, nil, nil
    navBg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = i.Position
            rootStart = root.Position
        end
    end)
    navBg.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - dragStart
            root.Position = UDim2.new(
                rootStart.X.Scale, rootStart.X.Offset + d.X,
                rootStart.Y.Scale, rootStart.Y.Offset + d.Y
            )
        end
    end)

    -- ── Toggle keybind ─────────────────────────────────────────────────────
    UserInputService.InputBegan:Connect(function(i, gpe)
        if not gpe and i.KeyCode == self.Toggle then
            sg.Enabled = not sg.Enabled
        end
    end)
end

-- ─────────────────────────────────────────────────────────────────────────────
--  AddTab
--  Each tab is a card (dark rounded panel) that slides in/out.
--  Tab buttons sit in the bottom navbar.
--  Icons are optional; fallback to short text labels.
-- ─────────────────────────────────────────────────────────────────────────────
function Window:AddTab(name, icon)
    local t = self.t
    local NAV_BTN_W = math.floor(
        (self._navList.AbsoluteSize.X > 0 and self._navList.AbsoluteSize.X or 488) /
        math.max(#self._tabs + 1, 1)
    )

    -- Nav button
    local navBtn = button({
        Text            = icon and "" or name,
        Size            = UDim2.new(1 / 8, 0, 1, 0), -- will be resized on tab add
        BackgroundTransparency = 1,
        TextColor3      = t.fgMuted,
        Font            = Enum.Font.GothamMedium,
        TextSize        = 11,
        ZIndex          = 5,
        LayoutOrder     = #self._tabs + 1,
        Parent          = self._navList,
    })

    -- If icon string given, show it as ImageLabel (Orca uses rbxassetid icons)
    if icon and icon:match("^rbxassetid://") then
        local img = Instance.new("ImageLabel")
        img.Size               = UDim2.new(0, 22, 0, 22)
        img.Position           = UDim2.new(0.5, -11, 0.5, -11)
        img.BackgroundTransparency = 1
        img.Image              = icon
        img.ImageColor3        = t.fgMuted
        img.ZIndex             = 6
        img.Parent             = navBtn
        -- Store for color tweening
        navBtn:SetAttribute("hasIcon", true)
        navBtn:SetAttribute("iconChild", img.Name)
    end

    -- Active indicator (thin accent line under button)
    local indicator = frame({
        Size     = UDim2.new(0, 0, 0, 2),
        Position = UDim2.new(0.5, 0, 1, -4),
        AnchorPoint = Vector2.new(0.5, 0),
        BackgroundColor3 = t.accentA,
        ZIndex = 6,
        Parent = navBtn,
    })
    corner(indicator, 1)

    -- ── Card (the scrollable content panel) ──────────────────────────────
    local card = frame({
        Size            = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = t.card,
        Visible         = false,
        Parent          = self._contentArea,
    })
    corner(card, t.rounding)
    addShadow(card, t.shadow, t.shadowT)

    local scroll = scrollFrame({
        Size              = UDim2.new(1, 0, 1, 0),
        ScrollBarImageColor3 = t.accentA,
        ZIndex            = card.ZIndex + 1,
        Parent            = card,
    })
    pad(scroll, 12, 12, 12, 12)
    list(scroll, Enum.FillDirection.Vertical, 6)

    -- Tab object
    local tab     = Tab.new(scroll, t)
    tab._card     = card
    tab._navBtn   = navBtn
    tab._indicator = indicator

    local function activate()
        for _, existingTab in ipairs(self._tabs) do
            existingTab._card.Visible = false
            snap(existingTab._navBtn, { TextColor3 = t.fgMuted })
            snap(existingTab._indicator, { Size = UDim2.new(0, 0, 0, 2) })
            -- Icon color
            for _, c in ipairs(existingTab._navBtn:GetChildren()) do
                if c:IsA("ImageLabel") then snap(c, { ImageColor3 = t.fgMuted }) end
            end
        end
        card.Visible = true

        -- Slide-in from slightly below
        card.Position = UDim2.new(0, 0, 0, 12)
        card.BackgroundTransparency = 0.3
        spring(card, { Position = UDim2.new(0,0,0,0), BackgroundTransparency = 0 }, 0.3,
            Enum.EasingStyle.Back, Enum.EasingDirection.Out)

        snap(navBtn, { TextColor3 = t.fg })
        spring(indicator, { Size = UDim2.new(0.6, 0, 0, 2) }, 0.25, Enum.EasingStyle.Back)
        for _, c in ipairs(navBtn:GetChildren()) do
            if c:IsA("ImageLabel") then snap(c, { ImageColor3 = t.accentA }) end
        end
        self._activeTab = tab
    end

    tab._activate = activate
    navBtn.Activated:Connect(activate)

    -- Resize nav buttons evenly
    local count = #self._tabs + 1
    for i, existingTab in ipairs(self._tabs) do
        existingTab._navBtn.Size = UDim2.new(1 / count, 0, 1, 0)
    end
    navBtn.Size = UDim2.new(1 / count, 0, 1, 0)

    table.insert(self._tabs, tab)
    if #self._tabs == 1 then
        task.defer(activate)
    end

    return tab
end

function Window:SetVisible(v)
    self._gui.Enabled = v
end

function Window:Destroy()
    local root = self._root
    spring(root, {
        Size = UDim2.new(0, root.AbsoluteSize.X, 0, 0)
    }, 0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
    local scale = root:FindFirstChildWhichIsA("UIScale")
    if scale then spring(scale, { Scale = 0.9 }, 0.2) end
    task.delay(0.3, function() self._gui:Destroy() end)
end

-- ─── Public API ───────────────────────────────────────────────────────────────

local OrcaUI = {}

function OrcaUI.new(title, options)
    return Window.new(title, options)
end

OrcaUI.Themes = Themes

return OrcaUI
