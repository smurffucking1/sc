        Accent = Color3.fromRGB(65, 130, 255),
        Accent2 = Color3.fromRGB(90, 90, 110),
        Text = Color3.fromRGB(240, 240, 255),
        SubText = Color3.fromRGB(170, 170, 190),
        TabInactive = Color3.fromRGB(35, 35, 45),
        TabActive = Color3.fromRGB(65, 130, 255),
    },
    Light = {
        Background = Color3.fromRGB(235, 235, 240),
        Accent = Color3.fromRGB(50, 120, 255),
        Accent2 = Color3.fromRGB(210, 210, 220),
        Text = Color3.fromRGB(20, 20, 30),
        SubText = Color3.fromRGB(80, 80, 100),
        TabInactive = Color3.fromRGB(210, 210, 225),
        TabActive = Color3.fromRGB(50, 120, 255),
    },
    AMOLED = {
