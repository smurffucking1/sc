    },
}

function Library:GetThemes()
    local names = {}
    for name in pairs(self.Themes) do
        table.insert(names, name)
    end
    table.sort(names)
    return names
end

function Library:SetTheme(name)
    if not self.Themes[name] then
        return
    end
    self.Theme = self.Themes[name]
    self.Theme.Name = name
    Library.Theme = self.Theme
end

-- Window object
local Window = {}
Window.__index = Window

-- Tab object
local Tab = {}
Tab.__index = Tab

-- Blur helper
local function getOrCreateBlur()
    local blur = Lighting:FindFirstChildOfClass("BlurEffect")
    if not blur then
        blur = Instance.new("BlurEffect")
        blur.Size = 0
        blur.Enabled = false
        blur.Parent = Lighting
    end
    return blur
end

function Library:CreateWindow(options)
    options = options or {}
    local selfLib = setmetatable({}, Library)

    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")

    local themeName = options.DefaultTheme or "Dark"
    selfLib:SetTheme(themeName)

    local blur = getOrCreateBlur()

    -- MAIN WINDOW GUI
    local mainGui = Instance.new("ScreenGui")
    mainGui.Name = (options.Title or "MyUILib") .. "_Main"
    mainGui.IgnoreGuiInset = true
    mainGui.ResetOnSpawn = false
    mainGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    mainGui.DisplayOrder = 9999
    mainGui.Parent = playerGui

    -- full-screen input blocker to prevent click-through
    local blocker = Instance.new("TextButton")
    blocker.Name = "InputBlocker"
    blocker.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    blocker.BackgroundTransparency = 1
    blocker.BorderSizePixel = 0
    blocker.Size = UDim2.new(1, 0, 1, 0)
    blocker.Position = UDim2.new(0, 0, 0, 0)
    blocker.Text = ""
    blocker.AutoButtonColor = false
    blocker.Modal = true
    blocker.Parent = mainGui

    -- TASKBAR GUI
    local barGui = Instance.new("ScreenGui")
    barGui.Name = (options.Title or "MyUILib") .. "_Bar"
    barGui.IgnoreGuiInset = true
    barGui.ResetOnSpawn = false
    barGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    barGui.DisplayOrder = 9999
    barGui.Parent = playerGui

    -- MAIN WINDOW CONTAINER
    local container = Instance.new("Frame")
    container.Name = "MainContainer"
    container.Size = UDim2.new(0, 500, 0, 320)
    container.Position = UDim2.new(0.5, -250, 0.5, -160)
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.Parent = mainGui

    local rootFrame = Instance.new("Frame")
    rootFrame.Name = "MainFrame"
    rootFrame.Size = UDim2.new(1, 0, 1, 0)
    rootFrame.Position = UDim2.new(0, 0, 0, 0)
    rootFrame.BackgroundColor3 = selfLib.Theme.Background
    rootFrame.BorderSizePixel = 0
    rootFrame.Parent = container

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = rootFrame

    local topBar = Instance.new("Frame")
    topBar.Name = "TopBar"
    topBar.Size = UDim2.new(1, 0, 0, 32)
    topBar.BackgroundColor3 = selfLib.Theme.Accent2
    topBar.BorderSizePixel = 0
    topBar.Parent = rootFrame

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.BackgroundTransparency = 1
    titleLabel.Position = UDim2.new(0, 10, 0, 0)
    titleLabel.Size = UDim2.new(1, -20, 1, 0)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextColor3 = selfLib.Theme.Text
    titleLabel.TextSize = 16
    titleLabel.Text = (options.Title or "Window")
        .. (options.SubTitle and (" - " .. options.SubTitle) or "")
    titleLabel.Parent = topBar

    -- TASKBAR (dock-style, bottom)
    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.BackgroundColor3 = selfLib.Theme.Background
    tabBar.BorderSizePixel = 0
    tabBar.Size = UDim2.new(0, 420, 0, 56)             -- initial, will be resized
    tabBar.AnchorPoint = Vector2.new(0.5, 1)
    tabBar.Position = UDim2.new(0.5, 0, 1, -4)
    tabBar.Parent = barGui

    local tabHolder = Instance.new("Frame")
    tabHolder.Name = "TabHolder"
    tabHolder.BackgroundTransparency = 1
    tabHolder.Size = UDim2.new(1, -10, 1, -8)
    tabHolder.Position = UDim2.new(0, 5, 0, 4)
    tabHolder.Parent = tabBar

    local tabList = Instance.new("UIListLayout")
    tabList.FillDirection = Enum.FillDirection.Horizontal
    tabList.SortOrder = Enum.SortOrder.LayoutOrder
    tabList.Padding = UDim.new(0, 6)
    tabList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    tabList.VerticalAlignment = Enum.VerticalAlignment.Center
    tabList.Parent = tabHolder

    -- CONTENT
    local contentArea = Instance.new("Frame")
    contentArea.Name = "Content"
    contentArea.BackgroundColor3 = selfLib.Theme.Background
    contentArea.BorderSizePixel = 0
    contentArea.Size = UDim2.new(1, 0, 1, -32)
    contentArea.Position = UDim2.new(0, 0, 0, 32)
    contentArea.Parent = rootFrame

    local contentCorner = Instance.new("UICorner")
    contentCorner.CornerRadius = UDim.new(0, 10)
    contentCorner.Parent = contentArea

    local thisWindow = setmetatable({
        Library = selfLib,
        MainGui = mainGui,
        BarGui = barGui,
        Root = rootFrame,
        Container = container,
        TabBar = tabHolder,
        TabBarFrame = tabBar,
        ContentArea = contentArea,
        Tabs = {},
        ActiveTab = nil,
        Connections = {},
        DestroyKey = options.DestroyKey or Enum.KeyCode.RightShift,
        Blur = blur,
        TabBarAlignment = "Center",
        TabBarOffset = 0,
    }, Window)

    -- dynamic dock width + alignment
    local function updateTabHolderSize()
        local total = tabList.AbsoluteContentSize.X
        local padding = 20
        local width = math.max(total + padding, 120)

        tabBar.Size = UDim2.new(0, width, 0, 56)
        tabHolder.Size = UDim2.new(1, -10, 1, -8)

        local align = thisWindow.TabBarAlignment
        local offset = thisWindow.TabBarOffset

        if align == "Left" then
            tabBar.AnchorPoint = Vector2.new(0, 1)
            tabBar.Position = UDim2.new(0, 10 + offset, 1, -4)
        elseif align == "Right" then
            tabBar.AnchorPoint = Vector2.new(1, 1)
            tabBar.Position = UDim2.new(1, -10 + offset, 1, -4)
        else
            tabBar.AnchorPoint = Vector2.new(0.5, 1)
            tabBar.Position = UDim2.new(0.5, offset, 1, -4)
        end
    end

    tabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateTabHolderSize)
    updateTabHolderSize()

    -- disable CoreGui while this UI exists
    pcall(function()
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
    end)

    -- keybind: toggle UI + blur
    table.insert(thisWindow.Connections,
        UserInputService.InputBegan:Connect(function(input, gp)
            if gp then
                return
            end
            if input.KeyCode == thisWindow.DestroyKey then
                local newState = not thisWindow.MainGui.Enabled
                thisWindow.MainGui.Enabled = newState
                thisWindow.BarGui.Enabled = newState
                thisWindow.Blur.Enabled = newState
                thisWindow.Blur.Size = newState and 18 or 0
            end
        end)
    )

    -- slide-in main (from nearest horizontal edge)
    do
        local tweenInfo = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local currentPos = container.Position
        local fromPos

        if currentPos.X.Scale <= 0.5 then
            fromPos = UDim2.new(-0.2, currentPos.X.Offset, currentPos.Y.Scale, currentPos.Y.Offset)
        else
            fromPos = UDim2.new(1.2, currentPos.X.Offset, currentPos.Y.Scale, currentPos.Y.Offset)
        end

        container.Position = fromPos

        local tween = TweenService:Create(container, tweenInfo, {
            Position = currentPos,
        })
        tween:Play()
    end

    -- slide-up dock
    do
        local tweenInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local endPos = tabBar.Position
        local startPos = UDim2.new(endPos.X.Scale, endPos.X.Offset, 1, 60)

        tabBar.Position = startPos

        local tween = TweenService:Create(tabBar, tweenInfo, {
            Position = endPos,
        })
        tween:Play()
    end

    -- enable blur on open
    thisWindow.Blur.Enabled = true
    thisWindow.Blur.Size = 18

    return thisWindow
end

-- Window methods

function Window:SetToggleKey(keyCode)
    self.DestroyKey = keyCode
end

function Window:SetTabBarAlignment(alignment)
    alignment = alignment or "Center"
    alignment = string.lower(alignment)
    if alignment == "left" then
        self.TabBarAlignment = "Left"
    elseif alignment == "right" then
        self.TabBarAlignment = "Right"
    else
        self.TabBarAlignment = "Center"
    end
end

function Window:SetTabBarOffset(pixels)
    self.TabBarOffset = tonumber(pixels) or 0
end

function Window:Destroy()
    for _, conn in ipairs(self.Connections) do
        if conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(self.Connections)

    if self.MainGui and self.MainGui.Parent then
        self.MainGui:Destroy()
    end
    if self.BarGui and self.BarGui.Parent then
        self.BarGui:Destroy()
    end
    if self.Blur then
        self.Blur.Enabled = false
        self.Blur.Size = 0
    end

    pcall(function()
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
    end)
end

function Window:ShowTab(tab)
    local theme = self.Library.Theme
    if self.ActiveTab == tab then
        return
    end

    for _, t in ipairs(self.Tabs) do
        t.Content.Visible = false
        t.Button.BackgroundColor3 = theme.TabInactive
        t.Button.TextColor3 = theme.SubText
    end

    tab.Content.Visible = true
    tab.Button.BackgroundColor3 = theme.TabActive
    tab.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.ActiveTab = tab
end

local function getInitials(name)
    name = tostring(name or "")
    if #name == 0 then
        return "?"
    end
    return string.upper(string.sub(name, 1, 1))
end

function Window:AddTab(name)
    local theme = self.Library.Theme

    -- square tile button with initials
    local tabButton = Instance.new("TextButton")
    tabButton.Name = name .. "_TabButton"
    tabButton.Parent = self.TabBar
    tabButton.Size = UDim2.new(0, 40, 0, 40)
    tabButton.BackgroundColor3 = theme.TabInactive
    tabButton.BorderSizePixel = 0
    tabButton.AutoButtonColor = true
    tabButton.Font = Enum.Font.GothamBold
    tabButton.TextSize = 16
    tabButton.Text = getInitials(name)
    tabButton.TextColor3 = theme.Text

    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 8)
    buttonCorner.Parent = tabButton

    local contentFrame = Instance.new("ScrollingFrame")
    contentFrame.Name = name .. "_Content"
    contentFrame.Parent = self.ContentArea
    contentFrame.Size = UDim2.new(1, -10, 1, -10)
    contentFrame.Position = UDim2.new(0, 5, 0, 5)
    contentFrame.BackgroundTransparency = 1
    contentFrame.BorderSizePixel = 0
    contentFrame.ScrollBarThickness = 4
    contentFrame.Visible = false

    local list = Instance.new("UIListLayout")
    list.FillDirection = Enum.FillDirection.Vertical
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0, 4)
    list.Parent = contentFrame

    local tabObj = setmetatable({
        Window = self,
        Name = name,
        Button = tabButton,
        Content = contentFrame,
    }, Tab)

    table.insert(self.Connections,
        tabButton.MouseButton1Click:Connect(function()
            self:ShowTab(tabObj)
        end)
    )

    self.Tabs[name] = tabObj

    if not self.ActiveTab then
        self:ShowTab(tabObj)
    end

    return tabObj
end

-- ELEMENTS

function Tab:AddLabel(text)
    local theme = self.Window.Library.Theme

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = self.Content
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -10, 0, 24)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    return label
end

function Tab:AddButton(text, callback)
    callback = callback or function() end
    local theme = self.Window.Library.Theme

    local button = Instance.new("TextButton")
    button.Name = "Button"
    button.Parent = self.Content
    button.Size = UDim2.new(1, -10, 0, 28)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.AutoButtonColor = true
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.TextColor3 = theme.Text
    button.Text = text

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = button

    table.insert(self.Window.Connections,
        button.MouseButton1Click:Connect(function()
            task.spawn(callback)
        end)
    )

    return button
end

function Tab:AddToggle(text, default, callback)
    callback = callback or function() end
    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Toggle"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 28)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(1, -40, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    local box = Instance.new("TextButton")
    box.Name = "Box"
    box.Parent = holder
    box.Size = UDim2.new(0, 24, 0, 24)
    box.Position = UDim2.new(1, -26, 0.5, -12)
    box.BackgroundColor3 = theme.Accent2
    box.BorderSizePixel = 0
    box.AutoButtonColor = false
    box.Text = ""

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = box

    local state = default and true or false

    local function update()
        box.BackgroundColor3 = state and theme.Accent or theme.Accent2
    end

    update()
    callback(state)

    table.insert(self.Window.Connections,
        box.MouseButton1Click:Connect(function()
            state = not state
            update()
            task.spawn(callback, state)
        end)
    )

    return {
        Set = function(_, v)
            state = v and true or false
            update()
            callback(state)
        end,
        Get = function()
            return state
        end,
    }
end

