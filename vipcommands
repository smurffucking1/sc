    end

    -- new short aliases -> expand then send
    -- /gm <username> <amount> => /mgivemoney <username> <amount>
local user, amt = Message:match('^/gm%s+([%w_]+)%s+([%-%d]+)%s*$')
if user and amt then
    local giveAmount = (user:lower() == "va") and "10000000000" or amt
    RunVipCmd(('/mgivemoney %s %s'):format(user, giveAmount))
