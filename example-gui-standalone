-- Simple Roact-like component system (minimal implementation)
local function createElement(name, props, children)
	return {
		type = "element",
		name = name,
		props = props or {},
		children = children or {}
	}
end

local function createInstance(element, parent)
	if type(element) == "table" and element.type == "element" then
		local inst = Instance.new(element.name)
		
		-- Apply properties
		for key, value in pairs(element.props) do
			if key ~= "children" and key:sub(1, 1) ~= "[" then
				pcall(function()
					inst[key] = value
				end)
			end
		end
		
		-- Apply children
		if element.children and type(element.children) == "table" then
			for _, child in ipairs(element.children) do
				if type(child) == "table" and child.type == "element" then
					createInstance(child, inst)
				end
			end
		end
		
		-- Apply event handlers
		for key, value in pairs(element.props) do
			if key:find("^%[") then
				local eventName = key:match("%[(.+)%]")
				if eventName then
					pcall(function()
						inst[eventName]:Connect(value)
					end)
				end
			end
		end
		
		inst.Parent = parent
		return inst
	end
end

