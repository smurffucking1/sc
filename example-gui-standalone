-- Helper: Create styled button
local function createButton(name, color, position, callback, text)
	return createElement("TextButton", {
		Name = name,
		Size = UDim2.new(0, 85, 0, 50),
		Position = position,
		BackgroundColor3 = color,
		BackgroundTransparency = 0.1,
		BorderSizePixel = 0,
		Text = text or name,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 12,
		Font = Enum.Font.GothamBold,
		["[Activated]"] = callback,
		["[MouseEnter]"] = function()
			print("Hovering over " .. name)
		end,
		["[MouseLeave]"] = function()
			print("Left " .. name)
		end
	}, {
		createElement("UICorner", {
			CornerRadius = UDim.new(0, 6)
		}),
		createElement("UIStroke", {
			Thickness = 1,
			Color = Color3.fromRGB(200, 200, 200),
			Transparency = 0.5
		})
	})
end

-- Helper: Create slider
local function createSlider(position)
	local sliderFrame = Instance.new("Frame")
	sliderFrame.Name = "Slider"
	sliderFrame.Size = UDim2.new(1, -30, 0, 40)
	sliderFrame.Position = position
	sliderFrame.BackgroundColor3 = theme.button.background
	sliderFrame.BackgroundTransparency = 0.1
	sliderFrame.BorderSizePixel = 0
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = sliderFrame
	
	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 1
	stroke.Color = Color3.fromRGB(200, 200, 200)
	stroke.Transparency = 0.5
	stroke.Parent = sliderFrame
	
	-- Track
	local track = Instance.new("Frame")
	track.Name = "Track"
	track.Size = UDim2.new(1, -20, 0, 4)
	track.Position = UDim2.new(0, 10, 0.5, -2)
	track.BackgroundColor3 = theme.highlight.action1
	track.BackgroundTransparency = 0.3
	track.BorderSizePixel = 0
	track.Parent = sliderFrame
	
	-- Indicator
	local indicator = Instance.new("Frame")
	indicator.Name = "Indicator"
	indicator.Size = UDim2.new(0, 14, 0, 14)
	indicator.Position = UDim2.new(0, 10 + (guiState.sliderValue / 100) * (sliderFrame.AbsoluteSize.X - 40), 0.5, -7)
	indicator.BackgroundColor3 = theme.highlight.action1
	indicator.BackgroundTransparency = 0
	indicator.BorderSizePixel = 0
	indicator.Parent = sliderFrame
	
	local indCorner = Instance.new("UICorner")
	indCorner.CornerRadius = UDim.new(1, 0)
	indCorner.Parent = indicator
	
	-- Input handler
	local isDragging = false
	local function updateSlider(input)
		local relativeX = input.Position.X - sliderFrame.AbsolutePosition.X
		local percentage = math.clamp(relativeX / sliderFrame.AbsoluteSize.X, 0, 1)
		guiState.sliderValue = math.floor(percentage * 100)
		
		indicator.Position = UDim2.new(0, 10 + percentage * (sliderFrame.AbsoluteSize.X - 40), 0.5, -7)
		
		local valueLabel = sliderFrame.Parent:FindFirstChild("SliderValue")
		if valueLabel then
			valueLabel.Text = "Slider Value: " .. tostring(guiState.sliderValue)
		end
	end
	
	sliderFrame.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			isDragging = true
			updateSlider(input)
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input, gameProcessed)
		if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateSlider(input)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input, gameProcessed)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			isDragging = false
			print("Slider released at: " .. tostring(guiState.sliderValue))
		end
	end)
	
	return sliderFrame
end

