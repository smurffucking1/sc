-- MyUILib.lua

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local Library = {}
Library.__index = Library

-- Themes
Library.Themes = {
    Dark = {
        Background = Color3.fromRGB(20, 20, 25),
        Accent = Color3.fromRGB(65, 130, 255),
        Accent2 = Color3.fromRGB(90, 90, 110),
        Text = Color3.fromRGB(240, 240, 255),
        SubText = Color3.fromRGB(170, 170, 190),
        TabInactive = Color3.fromRGB(35, 35, 45),
        TabActive = Color3.fromRGB(65, 130, 255),
    },
    Light = {
        Background = Color3.fromRGB(235, 235, 240),
        Accent = Color3.fromRGB(50, 120, 255),
        Accent2 = Color3.fromRGB(210, 210, 220),
        Text = Color3.fromRGB(20, 20, 30),
        SubText = Color3.fromRGB(80, 80, 100),
        TabInactive = Color3.fromRGB(210, 210, 225),
        TabActive = Color3.fromRGB(50, 120, 255),
    },
    AMOLED = {
        Background = Color3.fromRGB(0, 0, 0),
        Accent = Color3.fromRGB(0, 170, 255),
        Accent2 = Color3.fromRGB(20, 20, 20),
        Text = Color3.fromRGB(255, 255, 255),
        SubText = Color3.fromRGB(130, 130, 130),
        TabInactive = Color3.fromRGB(10, 10, 10),
        TabActive = Color3.fromRGB(0, 170, 255),
    },
}

function Library:GetThemes()
    local names = {}
    for name in pairs(self.Themes) do
        table.insert(names, name)
    end
    table.sort(names)
    return names
end

function Library:SetTheme(name)
    if not self.Themes[name] then
        return
    end
    self.Theme = self.Themes[name]
    self.Theme.Name = name
    -- Theme propagation can be added later
end

-- Window object
local Window = {}
Window.__index = Window

-- Tab object
local Tab = {}
Tab.__index = Tab

function Library:CreateWindow(options)
    options = options or {}
    local selfLib = setmetatable({}, Library)

    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")

    local themeName = options.DefaultTheme or "Dark"
    selfLib:SetTheme(themeName)

    local gui = Instance.new("ScreenGui")
    gui.Name = options.Title or "MyUILib"
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = playerGui

    local rootFrame = Instance.new("Frame")
    rootFrame.Name = "MainFrame"
    rootFrame.Size = UDim2.new(0, 500, 0, 320)
    rootFrame.Position = UDim2.new(0.5, -250, 0.5, -160)
    rootFrame.BackgroundColor3 = selfLib.Theme.Background
    rootFrame.BorderSizePixel = 0
    rootFrame.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = rootFrame

    local topBar = Instance.new("Frame")
    topBar.Name = "TopBar"
    topBar.Size = UDim2.new(1, 0, 0, 32)
    topBar.BackgroundColor3 = selfLib.Theme.Accent2
    topBar.BorderSizePixel = 0
    topBar.Parent = rootFrame

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.BackgroundTransparency = 1
    titleLabel.Position = UDim2.new(0, 10, 0, 0)
    titleLabel.Size = UDim2.new(1, -20, 1, 0)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextColor3 = selfLib.Theme.Text
    titleLabel.TextSize = 16
    titleLabel.Text = (options.Title or "Window") ..
        (options.SubTitle and (" - " .. options.SubTitle) or "")
    titleLabel.Parent = topBar

    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.BackgroundColor3 = selfLib.Theme.Background
    tabBar.BorderSizePixel = 0
    tabBar.Size = UDim2.new(0, 140, 1, -32)
    tabBar.Position = UDim2.new(0, 0, 0, 32)
    tabBar.Parent = rootFrame

    local tabHolder = Instance.new("Frame")
    tabHolder.Name = "TabHolder"
    tabHolder.BackgroundTransparency = 1
    tabHolder.Size = UDim2.new(1, 0, 1, -10)
    tabHolder.Position = UDim2.new(0, 0, 0, 5)
    tabHolder.Parent = tabBar

    local tabList = Instance.new("UIListLayout")
    tabList.FillDirection = Enum.FillDirection.Vertical
    tabList.SortOrder = Enum.SortOrder.LayoutOrder
    tabList.Padding = UDim.new(0, 4)
    tabList.Parent = tabHolder

    local contentArea = Instance.new("Frame")
    contentArea.Name = "Content"
    contentArea.BackgroundColor3 = selfLib.Theme.Background
    contentArea.BorderSizePixel = 0
    contentArea.Size = UDim2.new(1, -140, 1, -32)
    contentArea.Position = UDim2.new(0, 140, 0, 32)
    contentArea.Parent = rootFrame

    local contentCorner = Instance.new("UICorner")
    contentCorner.CornerRadius = UDim.new(0, 10)
    contentCorner.Parent = contentArea

    local thisWindow = setmetatable({
        Library = selfLib,
        Gui = gui,
        Root = rootFrame,
        TabBar = tabHolder,
        ContentArea = contentArea,
        Tabs = {},
        ActiveTab = nil,
        Connections = {},
        DestroyKey = options.DestroyKey or Enum.KeyCode.RightShift,
    }, Window)

    -- keybind to toggle visibility
    table.insert(thisWindow.Connections,
        UserInputService.InputBegan:Connect(function(input, gp)
            if gp then
                return
            end
            if input.KeyCode == thisWindow.DestroyKey then
                thisWindow.Gui.Enabled = not thisWindow.Gui.Enabled
            end
        end)
    )

    return thisWindow
end

-- Window methods

function Window:SetToggleKey(keyCode)
    self.DestroyKey = keyCode
end

function Window:Destroy()
    for _, conn in ipairs(self.Connections) do
        if conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(self.Connections)

    if self.Gui and self.Gui.Parent then
        self.Gui:Destroy()
    end
end

function Window:ShowTab(tab)
    local theme = self.Library.Theme
    if self.ActiveTab == tab then
        return
    end

    for _, t in pairs(self.Tabs) do
        t.Content.Visible = false
        t.Button.BackgroundColor3 = theme.TabInactive
        t.Button.TextColor3 = theme.SubText
    end

    tab.Content.Visible = true
    tab.Button.BackgroundColor3 = theme.TabActive
    tab.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.ActiveTab = tab
end

function Window:AddTab(name)
    local theme = self.Library.Theme

    local tabButton = Instance.new("TextButton")
    tabButton.Name = name .. "_TabButton"
    tabButton.Parent = self.TabBar
    tabButton.Size = UDim2.new(1, 0, 0, 28)
    tabButton.BackgroundColor3 = theme.TabInactive
    tabButton.BorderSizePixel = 0
    tabButton.AutoButtonColor = false
    tabButton.Font = Enum.Font.Gotham
    tabButton.TextSize = 14
    tabButton.Text = name
    tabButton.TextColor3 = theme.Text

    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 6)
    buttonCorner.Parent = tabButton

    local contentFrame = Instance.new("ScrollingFrame")
    contentFrame.Name = name .. "_Content"
    contentFrame.Parent = self.ContentArea
    contentFrame.Size = UDim2.new(1, -10, 1, -10)
    contentFrame.Position = UDim2.new(0, 5, 0, 5)
    contentFrame.BackgroundTransparency = 1
    contentFrame.BorderSizePixel = 0
    contentFrame.ScrollBarThickness = 4
    contentFrame.Visible = false

    local list = Instance.new("UIListLayout")
    list.FillDirection = Enum.FillDirection.Vertical
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0, 4)
    list.Parent = contentFrame

    local tabObj = setmetatable({
        Window = self,
        Name = name,
        Button = tabButton,
        Content = contentFrame,
    }, Tab)

    table.insert(self.Connections,
        tabButton.MouseButton1Click:Connect(function()
            self:ShowTab(tabObj)
        end)
    )

    self.Tabs[name] = tabObj

    if not self.ActiveTab then
        self:ShowTab(tabObj)
    end

    return tabObj
end

-- Tab element helpers

function Tab:AddLabel(text)
    local theme = self.Window.Library.Theme

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = self.Content
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -10, 0, 24)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    return label
end

function Tab:AddButton(text, callback)
    callback = callback or function() end
    local theme = self.Window.Library.Theme

    local button = Instance.new("TextButton")
    button.Name = "Button"
    button.Parent = self.Content
    button.Size = UDim2.new(1, -10, 0, 28)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.AutoButtonColor = true
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.TextColor3 = theme.Text
    button.Text = text

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = button

    table.insert(self.Window.Connections,
        button.MouseButton1Click:Connect(function()
            task.spawn(callback)
        end)
    )

    return button
end

function Tab:AddToggle(text, default, callback)
    callback = callback or function() end
    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Toggle"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 28)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(1, -40, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    local box = Instance.new("TextButton")
    box.Name = "Box"
    box.Parent = holder
    box.Size = UDim2.new(0, 24, 0, 24)
    box.Position = UDim2.new(1, -26, 0.5, -12)
    box.BackgroundColor3 = theme.Accent2
    box.BorderSizePixel = 0
    box.AutoButtonColor = false
    box.Text = ""
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = box

    local state = default and true or false

    local function update()
        box.BackgroundColor3 = state and theme.Accent or theme.Accent2
    end

    update()
    callback(state)

    table.insert(self.Window.Connections,
        box.MouseButton1Click:Connect(function()
            state = not state
            update()
            task.spawn(callback, state)
        end)
    )

    return {
        Set = function(_, v)
            state = v and true or false
            update()
            callback(state)
        end,
        Get = function()
            return state
        end,
    }
end

-- Simple Keybind element (for Settings)
function Tab:AddKeybind(text, initialKey, callback)
    callback = callback or function() end
    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Keybind"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 28)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(1, -80, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    local button = Instance.new("TextButton")
    button.Name = "KeyButton"
    button.Parent = holder
    button.Size = UDim2.new(0, 60, 0, 24)
    button.Position = UDim2.new(1, -62, 0.5, -12)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.Font = Enum.Font.Gotham
    button.TextSize = 12
    button.TextColor3 = theme.Text

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = button

    local currentKey = initialKey or Enum.KeyCode.RightShift
    button.Text = currentKey.Name

    local listening = false

    local function setKey(keyCode)
        currentKey = keyCode
        button.Text = currentKey.Name
        callback(currentKey)
    end

    table.insert(self.Window.Connections,
        button.MouseButton1Click:Connect(function()
            if listening then
                return
            end
            listening = true
            button.Text = "..."
            local conn
            conn = UserInputService.InputBegan:Connect(function(input, gp)
                if gp then
                    return
                end
                if input.KeyCode ~= Enum.KeyCode.Unknown then
                    setKey(input.KeyCode)
                    listening = false
                    if conn and conn.Connected then
                        conn:Disconnect()
                    end
                end
            end)
        end)
    )

    return {
        Get = function()
            return currentKey
        end,
        Set = function(_, keyCode)
            setKey(keyCode)
        end,
    }
end

