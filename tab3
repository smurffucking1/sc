    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = labelText

    local box = Instance.new("TextBox")
    box.Name = "Input"
    box.Parent = holder
    box.Size = UDim2.new(0.5, -4, 1, 0)
    box.Position = UDim2.new(0.5, 4, 0, 0)
    box.BackgroundColor3 = theme.Accent2
    box.BorderSizePixel = 0
    box.Font = Enum.Font.Gotham
    box.TextSize = 14
    box.TextColor3 = theme.Text
    box.PlaceholderText = placeholder or ""
    box.Text = defaultText or ""

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = box

    box.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            onSubmit(box.Text)
        end
    end)

    return box
end

-- Dropdown with push-down behavior + simple search
function Tab:AddDropdown(text, items, default, callback)
    callback = callback or function() end
    items = items or {}

    local theme = self.Window.Library.Theme

    local holder = Instance.new("Frame")
    holder.Name = "Dropdown"
    holder.Parent = self.Content
    holder.Size = UDim2.new(1, -10, 0, 32) -- will resize when open
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = holder
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = theme.Text
    label.Text = text

    local button = Instance.new("TextButton")
    button.Name = "MainButton"
    button.Parent = holder
    button.Size = UDim2.new(0.5, -4, 1, 0)
    button.Position = UDim2.new(0.5, 4, 0, 0)
    button.BackgroundColor3 = theme.Accent2
    button.BorderSizePixel = 0
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.TextColor3 = theme.Text
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.Text = tostring(default or "Select")

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = button

    local menu = Instance.new("Frame")
    menu.Name = "Menu"
    menu.Parent = holder
    menu.BackgroundColor3 = theme.Background
    menu.BorderSizePixel = 0
    menu.Position = UDim2.new(0.5, 4, 1, 2) -- inside holder, under button
    menu.Size = UDim2.new(0.5, -4, 0, 0)
    menu.Visible = false
    menu.ClipsDescendants = true
    menu.ZIndex = 50

    local menuCorner = Instance.new("UICorner")
    menuCorner.CornerRadius = UDim.new(0, 6)
    menuCorner.Parent = menu

    local list = Instance.new("UIListLayout")
    list.FillDirection = Enum.FillDirection.Vertical
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0, 2)
    list.Parent = menu

    local opened = false
    local currentValue = default
    local baseHeight = 32

    local searchBox

    local function updateHolderHeight()
        if opened then
            holder.Size = UDim2.new(1, -10, 0, baseHeight + menu.Size.Y.Offset + 4)
        else
            holder.Size = UDim2.new(1, -10, 0, baseHeight)
        end
    end

    local function rebuildMenu(filterText)
        filterText = filterText or ""
        filterText = string.lower(filterText)

        for _, child in ipairs(menu:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("TextBox") then
                child:Destroy()
            end
        end

        -- Search box
        searchBox = Instance.new("TextBox")
        searchBox.Name = "Search"
        searchBox.Parent = menu
        searchBox.BackgroundColor3 = theme.Accent2
        searchBox.BorderSizePixel = 0
        searchBox.Size = UDim2.new(1, -4, 0, 24)
        searchBox.Position = UDim2.new(0, 2, 0, 2)
        searchBox.Font = Enum.Font.Gotham
        searchBox.TextSize = 14
        searchBox.TextColor3 = theme.Text
        searchBox.PlaceholderText = "Search..."
        searchBox.Text = filterText or ""
        searchBox.ZIndex = 51

        local searchCorner = Instance.new("UICorner")
        searchCorner.CornerRadius = UDim.new(0, 4)
        searchCorner.Parent = searchBox

        local visibleCount = 0

        local function addOption(v)
            local opt = Instance.new("TextButton")
            opt.Name = "Option"
            opt.Parent = menu
            opt.BackgroundColor3 = theme.Accent2
            opt.BorderSizePixel = 0
            opt.Size = UDim2.new(1, -4, 0, 24)
            opt.Font = Enum.Font.Gotham
            opt.TextSize = 14
            opt.TextColor3 = theme.Text
            opt.TextXAlignment = Enum.TextXAlignment.Left
            opt.Text = tostring(v)
            opt.ZIndex = 51

            local c = Instance.new("UICorner")
            c.CornerRadius = UDim.new(0, 4)
            c.Parent = opt

            visibleCount += 1

            table.insert(self.Window.Connections,
                opt.MouseButton1Click:Connect(function()
                    currentValue = v
                    button.Text = tostring(v)
                    callback(v)
                    opened = false
                    menu.Visible = false
                    updateHolderHeight()
                end)
            )
        end

        for _, v in ipairs(items) do
            local s = tostring(v)
            if filterText == "" or string.find(string.lower(s), filterText, 1, true) then
                addOption(v)
            end
        end

        -- 24 search + 4 padding + options
        local h = 24 + 4 + visibleCount * 26 + 4
        menu.Size = UDim2.new(menu.Size.X.Scale, menu.Size.X.Offset, 0, h)
        updateHolderHeight()

        searchBox:GetPropertyChangedSignal("Text"):Connect(function()
            rebuildMenu(searchBox.Text)
        end)
    end

    rebuildMenu("")

    table.insert(self.Window.Connections,
        button.MouseButton1Click:Connect(function()
            opened = not opened
            if opened then
                rebuildMenu(searchBox and searchBox.Text or "")
            end
            menu.Visible = opened
            updateHolderHeight()
        end)
    )

    if default ~= nil then
        currentValue = default
        button.Text = tostring(default)
        callback(default)
    end

    local api = {}

    function api:Set(value)
        currentValue = value
        button.Text = tostring(value)
        callback(value)
    end

    function api:Get()
        return currentValue
    end

    function api:SetItems(newItems)
        items = newItems or {}
        if opened then
            rebuildMenu(searchBox and searchBox.Text or "")
        end
    end

    return api
end

return Library
